<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <title>Cămara Fermei BoCO</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div id="continut-principal">
        <h1>Salut, fermierule <%= user %>!</h1>
        
        <p>Ai vizitat magazinul de <strong><%= views %></strong> ori în această sesiune.</p>

        <% if (ultimaVizita) { %>

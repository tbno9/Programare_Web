<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login – Ferma BoCo</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <div class="auth-page">
    <div class="auth-card">

      <div class="auth-logo">
        <span class="auth-logo-icon">🌿</span>
        <div>
          <p class="auth-logo-name">Ferma BoCo</p>
          <p class="auth-logo-sub">Magazin online</p>
        </div>
      </div>

      <h2>Bun venit înapoi</h2>
      <p class="auth-subtitle">Introdu datele tale pentru a accesa magazinul</p>

      <% if (locals.eroare) { %>
        <div class="auth-error"><%= eroare %></div>
      <% } %>

      <form method="POST" action="/login">
        <div class="field">
          <label for="email">Adresă email</label>
          <input type="email" id="email" name="email" placeholder="ex: ion@ferma.ro" required>
        </div>
        <div class="field">
          <label for="password">Parolă</label>
          <input type="password" id="password" name="password" placeholder="••••••••" required>
        </div>
        <button type="submit" class="btn-primary">Intră în cont</button>
      </form>

      <p class="auth-link">Nu ai cont? <a href="/register">Înregistrează-te</a></p>

    </div>
  </div>

</body>
</html>